# Database
DATABASE_URL=postgresql://postgres:Musab1122@localhost:5432/studyai

# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-here
# In production set to your deployed URL, e.g. https://studyai.my
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Optional: additional trusted origins (comma-separated). Keep this strict in production.
# TRUSTED_ORIGINS=https://www.studyai.my,https://studyai.my

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: http://localhost:3001/api/auth/callback/google
# (also add http://localhost:3000/... if you use port 3000)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Provider: gemini | openai | gateway (auto-detects if empty)
AI_PROVIDER=gemini

# Option 1: Google Gemini (recommended - free tier available)
# Get key: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Option 2: Direct OpenAI
OPENAI_API_KEY=

# Option 3: Vercel AI Gateway (supports Gemini + OpenAI + Claude)
AI_GATEWAY_API_KEY=your-ai-gateway-token
VERCEL_AI_GATEWAY_TOKEN=your-ai-gateway-token

# Optional: override default model
# AI_MODEL=gemini-2.5-flash

# Environment
NODE_ENV=development
